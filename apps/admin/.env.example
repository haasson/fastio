# Supabase (Settings → API)
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NUXT_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Yandex Maps (https://developer.tech.yandex.ru/)
NUXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-api-key

# DaData (https://dadata.ru/)
NUXT_DADATA_API_KEY=your-dadata-api-key

# OpenAI (AI assistant)
NUXT_OPENAI_API_KEY=

# Telegram — tenant notifications bot (orders, reservations, kitchen)
NUXT_TELEGRAM_TENANT_BOT_TOKEN=your-tenant-bot-token
NUXT_PUBLIC_TELEGRAM_TENANT_BOT_USERNAME=your_tenant_bot_username

# Telegram — client auth bot (storefront login)
# NUXT_ADMIN_URL is required so the plugin can register the webhook with Telegram
NUXT_TELEGRAM_CLIENT_BOT_TOKEN=your-client-bot-token
NUXT_ADMIN_URL=https://app.fastio.ru
NUXT_TELEGRAM_AUTH_WEBHOOK_URL=
NUXT_TELEGRAM_TENANT_WEBHOOK_URL=
# NUXT_TELEGRAM_WEBHOOK_SECRET=your-webhook-secret  # optional but recommended

# Telegram — ops bot (alerts to ops chat)
NUXT_TELEGRAM_OPS_BOT_TOKEN=
NUXT_TELEGRAM_ALERT_CHAT_ID=

# Telegram HTTP-прокси (api.telegram.org заблокирован РКН → нужен прокси из РФ-VPS).
# sing-box HTTP-inbound на VPS, например 127.0.0.1:1081 → проксирует на VLESS.
# undici.ProxyAgent поддерживает только HTTP(S) прокси, не SOCKS.
# В Coolify задавать с учётом docker-сети (host.docker.internal / bridge gateway).
# Не задавать локально — Telegram доступен напрямую.
NUXT_TELEGRAM_PROXY_URL=

# Reminder cron secret (HMAC для cron-callback'ов из supabase → admin)
NUXT_REMINDER_CRON_SECRET=

# Internal API secret (для internal endpoint'ов admin↔edge)
NUXT_INTERNAL_API_SECRET=

# Trusted proxy для rate-limit / IDOR-guard (см. apps/admin/server/utils/clientIp.ts).
# В проде ОБЯЗАТЕЛЬНО задать обе переменные если перед приложением стоит reverse proxy
# (Vercel, Coolify-за-Traefik, nginx). Без них любые user-controlled заголовки
# IGNORируются и IP берётся из TCP-сокета — безопасный default для dev/preview.
#
# Vercel:              TRUST_PROXY=1, TRUSTED_IP_HEADER=x-real-ip
# Coolify + Traefik:   TRUST_PROXY=1, TRUSTED_IP_HEADER=x-real-ip
# Dev/preview:         не задавать
TRUST_PROXY=
TRUSTED_IP_HEADER=
