# Firebase Web SDK (Project Settings → Your apps → Web app)
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (Project Settings → Service accounts → Generate new private key)
# Вставь содержимое JSON-файла целиком одной строкой (или используй base64)
NUXT_FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"..."}
