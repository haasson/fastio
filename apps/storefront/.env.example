# Supabase (Settings → API)
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NUXT_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DaData (https://dadata.ru/)
NUXT_DADATA_API_KEY=your-dadata-api-key

# Yandex Maps (https://developer.tech.yandex.ru/)
NUXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-api-key

# Telegram — auth bot (storefront login via bot)
# The webhook handler lives in the admin app; storefront only needs token + public username
NUXT_TELEGRAM_AUTH_BOT_TOKEN=your-auth-bot-token
NUXT_PUBLIC_TELEGRAM_AUTH_BOT_USERNAME=your_auth_bot_username

# Telegram HTTP-прокси — см. apps/admin/.env.example (api.telegram.org заблокирован РКН).
# Storefront дёргает Telegram только в /api/appointments/remind-offer.
NUXT_TELEGRAM_PROXY_URL=

# Trusted proxy для rate-limit / IDOR-guard (см. apps/storefront/server/utils/clientIp.ts).
# В проде ОБЯЗАТЕЛЬНО задать обе переменные если перед приложением стоит reverse proxy
# (Vercel, Coolify-за-Traefik, nginx). Без них любые user-controlled заголовки
# IGNORируются и IP берётся из TCP-сокета — безопасный default для dev/preview.
#
# Vercel:              TRUST_PROXY=1, TRUSTED_IP_HEADER=x-real-ip
# Coolify + Traefik:   TRUST_PROXY=1, TRUSTED_IP_HEADER=x-real-ip
# Dev/preview:         не задавать
TRUST_PROXY=
TRUSTED_IP_HEADER=
