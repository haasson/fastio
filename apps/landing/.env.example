NUXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NUXT_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT private key — только local dev (auto-fill через pnpm backoffice:setup)
NUXT_SUPABASE_JWT_PRIVATE_KEY=

# URL админки — куда редиректить после регистрации тенанта
NUXT_ADMIN_URL=https://admin.fastio.ru

# Yandex Metrika (опционально)
NUXT_PUBLIC_YANDEX_METRIKA_ID=

# Yandex SmartCaptcha (server key — verifyCaptcha utility)
NUXT_YANDEX_CAPTCHA_SERVER_KEY=

# Server-to-server секрет для вызова Supabase edge функций (send-new-tenant-email).
# Должен совпадать с FASTIO_INTERNAL_TOKEN, заданным в edge секретах:
#   supabase secrets set FASTIO_INTERNAL_TOKEN=<random32>
NUXT_FASTIO_INTERNAL_TOKEN=

# Trusted proxy для rate-limit (см. apps/landing/server/utils/clientIp.ts).
# Vercel/Coolify: TRUST_PROXY=1, TRUSTED_IP_HEADER=x-real-ip
# Dev/preview: не задавать
TRUST_PROXY=
TRUSTED_IP_HEADER=
