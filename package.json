{
  "name": "fastio",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"pnpm dev:admin\" \"pnpm dev:storefront\"",
    "dev:storefront": "turbo run dev --filter=storefront",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:backoffice": "turbo run dev --filter=@fastio/backoffice",
    "dev:help": "turbo run dev --filter=@fastio/help",
    "dev:landing": "turbo run dev --filter=@fastio/landing",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:studio": "supabase studio",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:style": "stylelint \"apps/admin/**/*.{vue,scss,css}\" \"packages/**/*.{vue,scss,css}\"",
    "lint:style:fix": "pnpm lint:style --fix",
    "lint:style:admin": "stylelint \"apps/admin/**/*.{vue,scss,css}\"",
    "backoffice:setup": "node scripts/extract-local-jwt-key.mjs",
    "create-tenant": "node scripts/create-tenant.mjs",
    "create-tenant:remote": "node scripts/create-tenant.mjs",
    "supabase:deploy:functions": "supabase functions deploy",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "codemap:scan": "node scripts/codemap/scan.mjs",
    "features:validate": "node scripts/features/validate-manifests.mjs",
    "features:validate:strict": "node scripts/features/validate-manifests.mjs --strict",
    "features:gen-barrels": "node scripts/features/gen-barrels.mjs",
    "features:gen-barrels:check": "node scripts/features/gen-barrels.mjs --check",
    "new:feature": "node scripts/features/new-feature.mjs",
    "storefront-features:validate": "node scripts/storefront-features/validate-manifests.mjs",
    "storefront-features:validate:strict": "node scripts/storefront-features/validate-manifests.mjs --strict",
    "storefront-features:gen-barrels": "node scripts/storefront-features/gen-barrels.mjs",
    "storefront-features:gen-barrels:check": "node scripts/storefront-features/gen-barrels.mjs --check",
    "new:storefront-feature": "node scripts/storefront-features/new-feature.mjs",
    "audit:deps": "node scripts/audit-deps.mjs",
    "audit:deps:strict": "node scripts/audit-deps.mjs --strict",
    "audit:deps:graph": "node scripts/audit-deps.mjs --graph",
    "audit:realtime": "node scripts/audit-realtime.mjs",
    "audit:realtime:strict": "node scripts/audit-realtime.mjs --strict",
    "migration:impact": "node scripts/migration-impact.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/compiler-sfc": "^3.5.13",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "stylelint": "^17.7.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "ts-morph": "^28.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "tar@<7.5.11": ">=7.5.11 <8.0.0",
      "flatted@<3.4.2": ">=3.4.2 <4.0.0",
      "picomatch@<2.3.2": ">=2.3.2 <3.0.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4 <5.0.0",
      "lodash@<4.18.0": ">=4.18.0 <5.0.0",
      "lodash-es@<4.18.0": ">=4.18.0 <5.0.0",
      "defu@<6.1.5": ">=6.1.5 <7.0.0",
      "immutable@<5.1.5": ">=5.1.5 <6.0.0",
      "fast-uri@<3.1.2": ">=3.1.2 <4.0.0",
      "brace-expansion@<1.1.13": ">=1.1.13 <2.0.0",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3 <3.0.0",
      "yaml@<2.8.3": ">=2.8.3 <3.0.0",
      "postcss@<8.5.10": ">=8.5.10 <9.0.0",
      "devalue@<5.8.1": ">=5.8.1 <6.0.0",
      "h3@<1.15.11": ">=1.15.11 <2.0.0",
      "vue": "3.5.34",
      "@vue/runtime-core": "3.5.34",
      "@vue/runtime-dom": "3.5.34",
      "@vue/server-renderer": "3.5.34",
      "@vue/reactivity": "3.5.34",
      "@vue/shared": "3.5.34",
      "@vue/compiler-core": "3.5.34",
      "@vue/compiler-dom": "3.5.34",
      "@vue/compiler-ssr": "3.5.34"
    }
  }
}
