{
  "name": "fastio",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"pnpm dev:admin\" \"pnpm dev:storefront\"",
    "dev:storefront": "turbo run dev --filter=storefront",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:backoffice": "turbo run dev --filter=@fastio/backoffice",
    "dev:landing": "turbo run dev --filter=@fastio/landing",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:studio": "supabase studio",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "backoffice:setup": "node scripts/extract-local-jwt-key.mjs",
    "create-tenant": "node scripts/create-tenant.mjs",
    "create-tenant:remote": "node scripts/create-tenant.mjs",
    "supabase:deploy:functions": "supabase functions deploy",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
