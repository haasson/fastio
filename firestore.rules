rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Тенант: читать может только владелец
    match /tenants/{tenantId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.ownerId;

      // Категории и блюда: читать публично, писать — только владелец
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId;
      }

      match /dishes/{dishId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId;
      }

      // Заказы: создавать может кто угодно (покупатель), читать/обновлять — только владелец
      match /orders/{orderId} {
        allow create: if true;
        allow read, update: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId;
      }

      // Акции и промокоды: читать публично, писать — владелец
      match /promotions/{promotionId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId;
      }

      match /promoCodes/{codeId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId;
      }
    }
  }
}
