rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Фото блюд и баннеры — читать публично
    // Загружать — только аутентифицированный владелец тенанта
    match /tenants/{tenantId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid != null;
        // TODO: дополнительно проверять что uid == tenant.ownerId
    }
  }
}
